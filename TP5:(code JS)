//Exercice 2:
let nombresecret= Math.floor(Math.random()*10)+1;
let tentatives =0;
let x;
do{
    x=Number(prompt("Devinez un nombre entre 1 et 10"));
    tentatives++;
    if (x< nombresecret){
        alert ("entrez une valeur plus grand");
    }
    else if (x>nombresecret){
        alert  ("entrez une valeur plus petite ");
    }
}while (x!==nombresecret)
    alert("Bravo, vous avez trouvé en "+tentatives+"tentatives");
